# Required: Z.ai API key for the AI assistant (PatBot chatbot)
ZAI_API_KEY=

# Required: Database URL for Prisma (SQLite)
DATABASE_URL="file:./db/custom.db"

# Optional: Z.ai base URL (defaults to https://api.z.ai/api/paas/v4)
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Optional: NextAuth secret (if auth is configured)
# NEXTAUTH_SECRET=

# Optional: NextAuth URL (if auth is configured)
# NEXTAUTH_URL=https://patdilet.dev
